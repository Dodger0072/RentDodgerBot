BOT_TOKEN=your_bot_token_here
# Comma-separated Telegram user IDs (recommended for admin notifications)
ADMIN_USER_IDS=123456789,987654321
# Comma-separated usernames without @ (optional, for admin command access)
ADMIN_USERNAMES=admin1,admin2
# Telegram user IDs that may delete any item (including legacy shared). Optional.
SUPERADMIN_USER_IDS=
# SQLite database path (relative or absolute)
DATABASE_URL=sqlite+aiosqlite:///./rent_bot.db
# Display times in this timezone (IANA name)
DISPLAY_TZ=Europe/Moscow
# Suffix after local time (e.g. 03.04.2026 15:30 МСК). Leave empty to hide.
TIME_ZONE_LABEL=МСК

# If api.telegram.org is unreachable — pick ONE style:
# Full URL (HTTP or SOCKS):
# TELEGRAM_PROXY=http://127.0.0.1:7890
# TELEGRAM_PROXY=socks5h://user:pass@host:port
# Or one line from provider (default: SOCKS5):
# TELEGRAM_PROXY_LINE=host:port:username:password
# TELEGRAM_PROXY_SCHEME=socks5
#
# Если SOCKS «рвёт» соединение (WinError 10054): сначала попробуйте отключить удалённый DNS у SOCKS:
# TELEGRAM_SOCKS_RDNS=false
# Если не помогло — возможно прокси на самом деле HTTP, не SOCKS:
# TELEGRAM_PROXY_SCHEME=http
# TELEGRAM_REQUEST_TIMEOUT=120
